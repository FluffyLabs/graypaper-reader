{
  "name": "@fluffylabs/links-check",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FluffyLabs/graypaper-reader.git",
    "directory": "tools/links-check"
  },
  "version": "0.4.0",
  "description": "Check list of files for Gray Paper Reader links and make sure they are up to date.",
  "main": "./dist/index.js",
  "bin": {
    "gp-links-check": "bin/links-check.js"
  },
  "scripts": {
    "build": "tsc",
    "format": "biome format --write",
    "lint": "biome lint --write; biome check --write",
    "qa": "biome ci",
    "qa-fix": "npm run format; npm run lint",
    "start": "ts-node index.ts",
    "prepublish": "npm run build"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "author": "Fluffy Labs",
  "license": "MPL-2.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^25.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@fluffylabs/links-metadata": "^1.4.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5"
  }
}
